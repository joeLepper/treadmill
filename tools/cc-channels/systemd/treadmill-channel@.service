[Unit]
Description=Treadmill orchestrator session (label %i)
After=default.target

[Service]
Type=simple
# Idempotent launcher: creates the tmux session if missing,
# then sends the Claude launch into it. Foreground (stays
# alive for systemd to supervise).
ExecStart=%h/treadmill/tools/cc-channels/systemd/treadmill-channel-launch %i
Restart=on-failure
RestartSec=5s

[Install]
WantedBy=default.target
