#!/usr/bin/env bash
# Usage: treadmill-channel-launch <label>
#
# Idempotently brings up tmux session <label> and runs the
# cc-channels launcher inside it. Foreground process: stays
# alive while the tmux session exists (so systemd sees the
# service as live). Exits when the tmux session ends.
#
# Override the repo clone location with TREADMILL_REPO_DIR
# if you cloned somewhere other than $HOME/treadmill.
set -euo pipefail

# Record operator-initiated stop so a SIGTERM/SIGINT leaves the
# script with exit 0 (systemd then leaves the unit stopped per
# Restart=on-failure). An unexpected tmux-session end — claude
# crash, tmux kill-session, OOM kill, panic — falls through to
# exit 1 at the bottom so systemd restarts after RestartSec.
STOPPED_BY_OPERATOR=0
trap 'STOPPED_BY_OPERATOR=1' TERM INT

LABEL="${1:?label required}"
REPO_DIR="${TREADMILL_REPO_DIR:-$HOME/treadmill}"
LAUNCHER="$REPO_DIR/tools/cc-channels/launch-session.sh"

# Single-instance contract per ADR-0073: refuse to start
# if another launcher is alive for this label. The launcher
# itself enforces the same contract; we check up-front so
# systemd doesn't restart-loop against a competing run.
PIDFILE="$HOME/.cc-channels/$LABEL/launcher.pid"
if [ -f "$PIDFILE" ]; then
  PID=$(cat "$PIDFILE")
  # `kill -0` reports success on zombies (the PID slot is occupied, but the
  # process is `<defunct>` and won't be reaped until its parent exits or calls
  # wait()). The 2026-06-04 alan crash test surfaced this: SIGKILL'd claude
  # became a zombie under tmux; `kill -0` said "alive"; new wrapper attempts
  # all refused; systemd's Restart=on-failure looped without recovering. We
  # also check the process state via `ps`; a `Z` (zombie) is treated as dead
  # for our purposes so the singleton check doesn't block recovery.
  # `|| true` matters under `set -euo pipefail`: a dead PID makes `ps -p`
  # exit non-zero, pipefail propagates it through the pipeline, and the
  # command-substitution failure trips `set -e` — so without the `|| true`
  # the wrapper silently exits 1 on every stale-pidfile case (no stderr,
  # systemd Restart-loops forever). See the alan crash test after #186.
  STATE=$(ps -p "$PID" -o state= 2>/dev/null | head -c 1 || true)
  if kill -0 "$PID" 2>/dev/null && [ "$STATE" != "Z" ]; then
    echo "launcher already alive for label $LABEL (pid $PID); refusing to start" >&2
    exit 1
  fi
  # Stale or zombie; clean up.
  rm -f "$PIDFILE"
fi

# Ensure tmux session exists at the right cwd. systemd-user runs the wrapper
# with cwd=$HOME by default, so a bare `tmux new -d -s` would inherit that —
# but `claude --resume <session-id>` binds to a transcript stored under a
# slug derived from the cwd, so the wrong cwd silently loses the session.
# We persist the label's intended cwd via `launch-session.sh` writing it to
# `$STATE_ROOT/workdir`; fall back to $HOME/treadmill (matches the README
# default for alan/bert/carla) when the file is missing.
WORKDIR_FILE="$HOME/.cc-channels/$LABEL/workdir"
if [ -f "$WORKDIR_FILE" ]; then
  WORKDIR=$(cat "$WORKDIR_FILE")
else
  WORKDIR="${TREADMILL_REPO_DIR:-$HOME/treadmill}"
fi
if ! tmux has-session -t "$LABEL" 2>/dev/null; then
  tmux new -d -s "$LABEL" -c "$WORKDIR"
fi

# Send the launcher into the tmux session. `exec` so the
# tmux pane dies when the launcher exits, which lets the
# foreground loop below notice and return control to systemd.
tmux send-keys -t "$LABEL" "exec $LAUNCHER $LABEL" Enter

# Auto-dismiss the `--dangerously-load-development-channels` confirmation
# prompt and the workspace-trust prompt. Both fire on every fresh `claude`
# start (the dev-channels gate is per-launch, not per-session), so without
# this an unattended restart wedges waiting for the operator to press
# "1<Enter>". We poll the pane up to 60s for either prompt's distinctive
# text and send the accept keystroke when we see it. Background process —
# the foreground while-loop is what keeps the unit alive.
(
  sent_dev=0
  sent_trust=0
  for _ in $(seq 1 60); do
    sleep 1
    pane=$(tmux capture-pane -t "$LABEL" -p 2>/dev/null || true)
    case "$pane" in
      *"Loading development channels"*)
        if [ "$sent_dev" -eq 0 ]; then
          tmux send-keys -t "$LABEL" "1" Enter
          sent_dev=1
        fi
        ;;
      *"trust this folder"*)
        if [ "$sent_trust" -eq 0 ]; then
          tmux send-keys -t "$LABEL" "1" Enter
          sent_trust=1
        fi
        ;;
    esac
    # Done once both prompts are past us — claude's TUI footer ("bypass
    # permissions on" / "esc to interrupt") signals we're through.
    case "$pane" in
      *"bypass permissions on"*) break ;;
    esac
  done
) &

# Keep ourselves alive while the tmux session exists.
while tmux has-session -t "$LABEL" 2>/dev/null; do
  sleep 30
done

# Decide exit status. Operator-initiated stop (SIGTERM/SIGINT
# delivered by `systemctl --user stop`) flipped the trap flag —
# exit 0 so systemd's `Restart=on-failure` does not re-spawn.
# Any other tmux-ended cause is a crash by our definition and
# warrants restart.
if [ "$STOPPED_BY_OPERATOR" -eq 1 ]; then
  exit 0
fi
echo "treadmill-channel-launch: tmux session $LABEL ended unexpectedly; systemd will restart per Restart=on-failure" >&2
exit 1
