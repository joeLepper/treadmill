#!/usr/bin/env bash
# cc-attach <label>
#
# Attach to the supervised tmux session hosting the Claude orchestrator for
# <label> (ADR-0073). The session must be started via the systemd unit:
#   systemctl --user enable --now treadmill-channel@<label>.service
#
# Detach without killing the session: Ctrl-b d
set -euo pipefail

LABEL="${1:?usage: cc-attach <label>}"

if ! tmux has-session -t "$LABEL" 2>/dev/null; then
  cat >&2 <<EOF
[cc-attach] No supervised tmux session found for label '$LABEL'.

Start the supervised session first:
  systemctl --user enable --now treadmill-channel@$LABEL.service

Then re-run: cc-attach $LABEL
EOF
  exit 1
fi

exec tmux attach-session -t "$LABEL"
