{
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(npm *)",
      "Bash(node *)",
      "Bash(python3 *)",
      "Bash(uv *)",
      "Bash(pytest *)",
      "Bash(make *)",
      "Bash(ls *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(cat *)",
      "Bash(cd *)",
      "Bash(python3 ~/treadmill/tools/cc-channels/cc-relay.py *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${TREADMILL_TEAM_TEMPLATES_DIR:-$HOME/.treadmill/teams/__templates__}/worker/relay_inject_hook.py"
          }
        ]
      }
    ]
  }
}
