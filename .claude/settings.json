{
  "$comment": "Treadmill repo Claude Code settings. See ADR-0008 for the auto-capture hook and Stop-hook session-end sweep.",
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/tools/dev-hooks/capture_learning_candidate.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "uv run python $CLAUDE_PROJECT_DIR/tools/dev-hooks/review_candidates_at_stop.py"
          }
        ]
      }
    ]
  }
}
